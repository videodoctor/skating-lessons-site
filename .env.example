APP_NAME="Kristine's Skating"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://yourdomain.com

LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=skating_platform
DB_USERNAME=root
DB_PASSWORD=

BROADCAST_DRIVER=log
CACHE_DRIVER=file
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync
SESSION_DRIVER=file
SESSION_LIFETIME=120

# Mail Configuration
MAIL_MAILER=smtp
MAIL_HOST=smtp.mailtrap.io
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

# AWS S3 (for student media storage)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=kristineskates-media
AWS_USE_PATH_STYLE_ENDPOINT=false
# AWS_PROFILE=fr-local-dev  # Dev only — SSO profile. Staging/prod use EC2 IAM role.

# Student Media CDN (CloudFront)
MEDIA_CDN_URL=https://media.kristineskates.com
MEDIA_PATH_PREFIX=  # dev, staging, or prod. Dev/staging use signed S3 URLs; prod uses CloudFront CDN.

# Cloudflare Turnstile
TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# Venmo Configuration
VENMO_HANDLE=@kristine-skating
VENMO_DISPLAY_NAME=Kristine

# Twilio SMS
TWILIO_SID=
TWILIO_TOKEN=
TWILIO_FROM=

# Instructor Profile
INSTRUCTOR_NAME=Kristine
INSTRUCTOR_EMAIL=kristine@example.com
INSTRUCTOR_PHONE="(314) XXX-XXXX"
INSTRUCTOR_LOCATION="St. Louis County, MO"
